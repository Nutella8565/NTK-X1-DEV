{
  "name": "nutella-toolkit",
  "version": "1.3.9",
  "description": "Nutella Toolkit V1",
  "main": "Nutella-toolkit.js",
  "author": "Anonymus",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "pack": "electron-packager . Nutella-toolkit --platform=win32 --arch=x64 --out=dist --overwrite",
    "build": "electron-packager . Nutella-toolkit",
    "build:webpack": "webpack",
    "build-secure": "node --stack-size=10000 node_modules/webpack/bin/webpack.js --mode=production"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "build": {
    "appId": "com.nutella.toolkit",
    "productName": "Nutella-toolkit",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assests/icon.ico"
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2",
    "javascript-obfuscator": "^5.4.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-obfuscator": "^3.6.1"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "bufferutil": "^4.1.0",
    "cloudflared": "^0.5.2",
    "crypto-js": "^4.2.0",
    "discord.js": "^14.26.3",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "instagram-save": "^1.3.2",
    "instagram-scraper": "^1.0.6",
    "instagram-url-downloader": "^1.1.0",
    "keytar": "^7.9.0",
    "localtunnel": "^2.0.2",
    "ngrok": "^5.0.0-beta.2",
    "node-forge": "^1.4.0",
    "node-pty": "^1.1.0",
    "node-wifi": "^2.0.16",
    "nodemailer": "^8.0.4",
    "openvpn": "^0.1.5",
    "qr-code-styling-node": "^1.5.0",
    "qrcode": "^1.5.4",
    "robotjs": "^0.7.0",
    "sudo-prompt": "^9.2.1",
    "utf-8-validate": "^6.0.6",
    "wifi-password": "^3.0.1",
    "winreg": "^1.2.5",
    "wireguard": "^1.0.0",
    "ws": "^8.20.0",
    "youtube-dl-exec": "^3.1.4",
    "yt-dlp-wrap": "^2.3.12",
    "ytdl-core": "npm:@distube/ytdl-core@^4.16.12",
    "zlib-sync": "^0.1.10"
  }
}